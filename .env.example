# VeriClaw Docker Environment Configuration
# Copy this file to .env and fill in your values.
# See docs/operations.md for full deployment guide.

# ─── Discord Bridge ──────────────────────────────────────────────
DISCORD_BOT_TOKEN=your-discord-bot-token

# ─── Slack Bridge ────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_APP_TOKEN=xapp-your-slack-app-token

# ─── Email Bridge (IMAP/SMTP) ───────────────────────────────────
EMAIL_USER=you@example.com
EMAIL_PASS=your-email-password            # Use App Password for Gmail
# IMAP_HOST=imap.gmail.com
# IMAP_PORT=993
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587

# ─── IRC Bridge ──────────────────────────────────────────────────
IRC_PASS=your-irc-password
# IRC_HOST=irc.libera.chat
# IRC_PORT=6697
# IRC_TLS=true
# IRC_NICK=vericlaw
# IRC_CHANNELS=#general

# ─── Matrix Bridge ───────────────────────────────────────────────
MATRIX_TOKEN=your-matrix-access-token
MATRIX_USER_ID=@bot:matrix.org
# MATRIX_HOMESERVER=https://matrix.org

# ─── Mattermost Bridge ─────────────────────────────────────────
MATTERMOST_URL=https://mattermost.example.com
MATTERMOST_TOKEN=your-mattermost-bot-token
MATTERMOST_TEAM=my-team
MATTERMOST_CHANNEL=town-square

# ─── WhatsApp Bridge ────────────────────────────────────────────
# WA_PHONE=+1234567890                    # set for headless pairing

# ─── MCP Bridge (optional, use "mcp" profile) ───────────────────
# MCP_SERVERS=[]                          # JSON array of MCP server configs

# ─── Logging ─────────────────────────────────────────────────────
# LOG_LEVEL=info                          # debug | info | warning | error
