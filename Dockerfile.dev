# syntax=docker/dockerfile:1.7
# Development build environment for VeriClaw.
# Uses Ubuntu 22.04 (glibc 2.35) with system GNAT 12.
# - Ubuntu 24.04 (glibc 2.39) triggers a time_t build failure in aws 24.x.
# - GNAT 14.2.1 enforces stricter access discriminant rules that aws 24.x fails.
# System GNAT 12 (apt) matches the ubuntu-22.04 GitHub Actions runner used in CI.
#
# Build the image once: make docker-dev-image
# Then compile with source volume-mounted: make docker-dev-build
#
# Note: this image is linux/amd64. On Apple Silicon Docker runs it
# via QEMU emulation -- builds work, just ~2x slower.
FROM ubuntu:22.04

ARG DEBIAN_FRONTEND=noninteractive

RUN apt-get update \
    && apt-get install --yes --no-install-recommends \
       gnat \
       gprbuild \
       libsqlite3-dev \
       libcurl4-openssl-dev \
       curl \
       git \
       make \
       python3 \
       ca-certificates \
       unzip \
    && rm -rf /var/lib/apt/lists/* \
    && for t in gnatbind gnatlink gnatls; do \
         [ -f "/usr/bin/${t}-12" ] && ln -sf "/usr/bin/${t}-12" "/usr/bin/x86_64-linux-gnu-${t}" || true; \
       done

# Install Alire (Ada package manager) — manages gnatcoll + aws dependencies.
ARG ALIRE_VERSION=2.0.2
RUN curl -fsSL \
      "https://github.com/alire-project/alire/releases/download/v${ALIRE_VERSION}/alr-${ALIRE_VERSION}-bin-x86_64-linux.zip" \
      -o /tmp/alire.zip \
    && unzip -q /tmp/alire.zip -d /tmp/alire-extract/ \
    && find /tmp/alire-extract/ -name "alr" -type f -exec mv {} /usr/local/bin/alr \; \
    && rm -rf /tmp/alire.zip /tmp/alire-extract/ \
    && chmod +x /usr/local/bin/alr

# Pre-configure Alire so it doesn't prompt for user info on first run.
RUN alr settings --global --set user.email="dev@vericlaw.dev" \
    && alr settings --global --set user.name="VeriClaw Dev" \
    && alr settings --global --set distribution.unknown_os=false 2>/dev/null || true

ENV ALIRE_NONINTERACTIVE=true

WORKDIR /workspace
