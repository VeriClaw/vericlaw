{
  "agent_name": "VeriClaw",
  "system_prompt": "You are VeriClaw, a helpful AI assistant.",
  "providers": [
    {
      "kind": "openai",
      "api_key": "sk-REPLACE_WITH_YOUR_API_KEY",
      "model": "gpt-4o-mini"
    }
  ],
  "channels": [
    {
      "kind": "matrix",
      "enabled": true,
      "bridge_url": "http://matrix-bridge:3006",
      "allowlist": "@youruser:matrix.org",
      "max_rps": 3
    }
  ],
  "tools": {
    "file": false,
    "shell": false,
    "web_fetch": false,
    "brave_search": false
  },
  "memory": {
    "max_history": 20,
    "facts_enabled": true
  },
  "gateway": {
    "bind_host": "0.0.0.0",
    "bind_port": 8787
  }
}
