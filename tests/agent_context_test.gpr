project Agent_Context_Test is
   for Source_Dirs use (".", "../src", "../src/agent", "../src/config");
   for Main use ("agent_context_test.adb");

   package Compiler is
      for Default_Switches ("Ada") use ("-gnat2022", "-gnata", "-gnatVa");
   end Compiler;

   package Builder is
      for Global_Configuration_Pragmas use "../spark.adc";
   end Builder;
end Agent_Context_Test;
