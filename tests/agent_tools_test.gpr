with "gnatcoll";

project Agent_Tools_Test is
   for Source_Dirs use (".", "../src", "../src/agent", "../src/config",
                        "../src/providers", "../src/tools", "../src/http");
   for Main use ("agent_tools_test.adb");

   package Compiler is
      for Default_Switches ("Ada") use ("-gnat2022", "-gnata", "-gnatVa");
   end Compiler;

   package Linker is
      for Default_Switches ("Ada") use ("-lcurl");
   end Linker;

   package Builder is
      for Global_Configuration_Pragmas use "../spark.adc";
   end Builder;
end Agent_Tools_Test;
