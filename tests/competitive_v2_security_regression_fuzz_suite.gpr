project Competitive_V2_Security_Regression_Fuzz_Suite is
   for Source_Dirs use (".", "../src");
   for Main use ("competitive_v2_security_regression_fuzz_suite.adb");

   package Compiler is
      for Default_Switches ("Ada") use ("-gnat2022", "-gnata", "-gnatVa");
   end Compiler;

   package Builder is
      for Global_Configuration_Pragmas use "../spark.adc";
   end Builder;
end Competitive_V2_Security_Regression_Fuzz_Suite;
