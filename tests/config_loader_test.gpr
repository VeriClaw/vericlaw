with "gnatcoll";

project Config_Loader_Test is
   for Source_Dirs use (".", "../src", "../src/config");
   for Main use ("config_loader_test.adb");

   package Compiler is
      for Default_Switches ("Ada") use ("-gnat2022", "-gnata", "-gnatVa");
   end Compiler;

   package Builder is
      for Global_Configuration_Pragmas use "../spark.adc";
   end Builder;
end Config_Loader_Test;
