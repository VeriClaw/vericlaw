project Config_Migration_Policy is
   for Source_Dirs use (".", "../src");
   for Main use ("config_migration_policy.adb");

   package Compiler is
      for Default_Switches ("Ada") use ("-gnat2022", "-gnata", "-gnatVa");
   end Compiler;

   package Builder is
      for Global_Configuration_Pragmas use "../spark.adc";
   end Builder;
end Config_Migration_Policy;
