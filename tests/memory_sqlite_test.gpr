with "gnatcoll";
with "gnatcoll_sqlite";

project Memory_Sqlite_Test is
   for Source_Dirs use (".", "../src", "../src/agent", "../src/config",
                        "../src/memory");
   for Main use ("memory_sqlite_test.adb");

   package Compiler is
      for Default_Switches ("Ada") use ("-gnat2022", "-gnata", "-gnatVa");
   end Compiler;

   package Linker is
      for Default_Switches ("Ada") use ("-lsqlite3");
   end Linker;

   package Builder is
      for Global_Configuration_Pragmas use "../spark.adc";
   end Builder;
end Memory_Sqlite_Test;
