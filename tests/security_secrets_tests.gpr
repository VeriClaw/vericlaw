   for Main use ("security_secrets_tests.adb");

   package Compiler is
      for Default_Switches ("Ada") use ("-gnat2022", "-gnata", "-gnatVa");
   end Compiler;

   package Builder is
      for Global_Configuration_Pragmas use "../spark.adc";
   end Builder;
end Security_Secrets_Tests;
